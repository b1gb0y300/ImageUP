                                                       Foreground="#22D3EE" Margin="0,0,8,0"/>
                                            <Border Background="#1A2835" CornerRadius="12" Padding="8,3" VerticalAlignment="Center">
                                                <TextBlock Text="> 30 dB" FontSize="10" Foreground="#06B6D4" FontWeight="SemiBold"/>
                                            </Border>
