                                                   FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" LineHeight="18"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Column="1" Margin="5,0,0,0" CornerRadius="10" ClipToBounds="True"
