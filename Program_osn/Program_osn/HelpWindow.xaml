<Window x:Class="ImageEnhancementWpf.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Возможности — ImageUP"
        Width="840" Height="880"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
    </Window.Resources>

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource WindowBackgroundStartColor}" Offset="0"/>
            <GradientStop Color="{DynamicResource WindowBackgroundEndColor}" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Border Margin="14" Padding="20"
            Background="{DynamicResource CardBrush}"
            CornerRadius="18"
            Effect="{StaticResource CardShadow}"
            BorderBrush="{DynamicResource BorderSubtleBrush}"
            BorderThickness="1">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Возможности платформы ImageUP"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Что умеет приложение и для каких задач оно подходит"
                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>

                <Button Grid.Column="1" Content="Назад" Width="100" Height="36"
                        Style="{StaticResource GhostButton}"
                        Click="BackButton_Click"/>
            </Grid>

            <!-- ─── Основной контент: 2-колонная Golden Canon сетка ─────── -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <!-- φ⁻² ≈ 22% — навигация -->
                    <ColumnDefinition Width="200" MinWidth="160"/>
                    <!-- φ⁻¹ = 78% — контент -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── Левая: Навигация ─────────────────────────────── -->
                <Border Grid.Column="0"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}"
                        BorderThickness="0,0,1,0"
                        Padding="8,13,8,13">
                    <StackPanel>
                        <TextBlock Text="РАЗДЕЛЫ" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="8,0,0,13"/>
                        <Border x:Name="NavPurpose" Padding="8,7" CornerRadius="6" Cursor="Hand"
                                Margin="0,0,0,3" Background="{DynamicResource SurfaceInputBrush}"
                                MouseLeftButtonDown="NavPurpose_Click">
                            <TextBlock Text="📄 Назначение" FontSize="11"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>
                        <Border x:Name="NavFeatures" Padding="8,7" CornerRadius="6" Cursor="Hand"
                                Margin="0,0,0,3" Background="Transparent"
                                MouseLeftButtonDown="NavFeatures_Click">
                            <TextBlock Text="✦ Возможности" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                        <Border x:Name="NavHotkeys" Padding="8,7" CornerRadius="6" Cursor="Hand"
                                Margin="0,0,0,3" Background="Transparent"
                                MouseLeftButtonDown="NavHotkeys_Click">
                            <TextBlock Text="⌨ Горячие клавиши" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                        <Border x:Name="NavScenarios" Padding="8,7" CornerRadius="6" Cursor="Hand"
                                Margin="0,0,0,3" Background="Transparent"
                                MouseLeftButtonDown="NavScenarios_Click">
                            <TextBlock Text="💼 Сценарии" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                        <Border x:Name="NavMetrics" Padding="8,7" CornerRadius="6" Cursor="Hand"
                                Margin="0,0,0,3" Background="Transparent"
                                MouseLeftButtonDown="NavMetrics_Click">
                            <TextBlock Text="📊 Метрики" FontSize="11"
                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ─── Правая: Контент ──────────────────────────────── -->
                <ScrollViewer Grid.Column="1" x:Name="ContentScroller"
                              VerticalScrollBarVisibility="Auto" Padding="0,4,4,0">
                <Border Background="{DynamicResource SurfaceInputBrush}"
                        CornerRadius="14" Padding="20"
                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                    <StackPanel>

                        <TextBlock Text="Назначение приложения"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary2Brush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   LineHeight="22">
ImageUP — настольная платформа для улучшения и анализа изображений. Приложение сочетает классические методы цифровой обработки и нейросетевые алгоритмы, помогая быстро получать наглядный результат без сложных настроек и кода.
                        </TextBlock>

                        <TextBlock Text="Ключевые возможности"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary2Brush}"
                                   Margin="0,20,0,10"/>

                        <!-- ─── Method Category Cards (2×2) ─── -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Контраст & Коррекция -->
                            <Border Grid.Column="0" Grid.Row="0" Margin="0,0,5,5"
                                    CornerRadius="10" ClipToBounds="True"
                                    Background="{DynamicResource CardBrush}"
                                    BorderBrush="#2A2A38" BorderThickness="1">
                                <Grid>
                                    <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#6366F1" Offset="0"/>
                                                <GradientStop Color="#8B5CF6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel Margin="12,15,12,12">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Width="26" Height="26" CornerRadius="7"
                                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#6366F1" Opacity="0.15"/>
                                                </Border.Background>
                                                <TextBlock Text="◑" FontSize="13" Foreground="#6366F1"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Контраст" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondary2Brush}"
                                                       VerticalAlignment="Center"/>
                                            <Border Background="#6366F115" CornerRadius="8" Padding="6,2"
                                                    Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="5" FontSize="10" Foreground="#818CF8" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <WrapPanel>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="{DynamicResource SurfaceInputBrush}" Padding="6,3">
                                                <TextBlock Text="LinearContrast" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Border>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="{DynamicResource SurfaceInputBrush}" Padding="6,3">
                                                <TextBlock Text="EqHistogram" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Border>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="{DynamicResource SurfaceInputBrush}" Padding="6,3">
                                                <TextBlock Text="Gamma" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Border>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="#1E1E35" Padding="6,3">
                                                <TextBlock Text="CLAHE" FontSize="9" Foreground="#818CF8"/>
                                            </Border>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="{DynamicResource SurfaceInputBrush}" Padding="6,3">
                                                <TextBlock Text="MS-Retinex" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Шумоподавление -->
                            <Border Grid.Column="1" Grid.Row="0" Margin="5,0,0,5"
                                    CornerRadius="10" ClipToBounds="True"
                                    Background="{DynamicResource CardBrush}"
                                    BorderBrush="#2A2A38" BorderThickness="1">
                                <Grid>
                                    <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#06B6D4" Offset="0"/>
                                                <GradientStop Color="#0891B2" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel Margin="12,15,12,12">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Width="26" Height="26" CornerRadius="7"
                                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#06B6D4" Opacity="0.15"/>
                                                </Border.Background>
                                                <TextBlock Text="≋" FontSize="14" Foreground="#06B6D4"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Шумоподавление" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondary2Brush}"
                                                       VerticalAlignment="Center"/>
                                            <Border Background="#06B6D415" CornerRadius="8" Padding="6,2"
                                                    Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="4" FontSize="10" Foreground="#22D3EE" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <WrapPanel>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="{DynamicResource SurfaceInputBrush}" Padding="6,3">
                                                <TextBlock Text="Median" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Border>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="{DynamicResource SurfaceInputBrush}" Padding="6,3">
                                                <TextBlock Text="Bilateral" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Border>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="{DynamicResource SurfaceInputBrush}" Padding="6,3">
                                                <TextBlock Text="Wiener" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Border>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="#1A2835" Padding="6,3">
                                                <TextBlock Text="NLM" FontSize="9" Foreground="#22D3EE"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Резкость & Восстановление -->
                            <Border Grid.Column="0" Grid.Row="1" Margin="0,0,5,0"
                                    CornerRadius="10" ClipToBounds="True"
                                    Background="{DynamicResource CardBrush}"
                                    BorderBrush="#2A2A38" BorderThickness="1">
                                <Grid>
                                    <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#22C55E" Offset="0"/>
                                                <GradientStop Color="#16A34A" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel Margin="12,15,12,12">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Width="26" Height="26" CornerRadius="7"
                                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#22C55E" Opacity="0.15"/>
                                                </Border.Background>
                                                <TextBlock Text="◈" FontSize="13" Foreground="#22C55E"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Резкость" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondary2Brush}"
                                                       VerticalAlignment="Center"/>
                                            <Border Background="#22C55E15" CornerRadius="8" Padding="6,2"
                                                    Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="3" FontSize="10" Foreground="#4ADE80" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <WrapPanel>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="{DynamicResource SurfaceInputBrush}" Padding="6,3">
                                                <TextBlock Text="Unsharp Mask" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Border>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="{DynamicResource SurfaceInputBrush}" Padding="6,3">
                                                <TextBlock Text="Deconvolution" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Border>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="#18261C" Padding="6,3">
                                                <TextBlock Text="Real-ESRGAN" FontSize="9" Foreground="#4ADE80"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Анализ & Сегментация -->
                            <Border Grid.Column="1" Grid.Row="1" Margin="5,0,0,0"
                                    CornerRadius="10" ClipToBounds="True"
                                    Background="{DynamicResource CardBrush}"
                                    BorderBrush="#2A2A38" BorderThickness="1">
                                <Grid>
                                    <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#F59E0B" Offset="0"/>
                                                <GradientStop Color="#D97706" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel Margin="12,15,12,12">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <Border Width="26" Height="26" CornerRadius="7"
                                                    Margin="0,0,8,0" VerticalAlignment="Center">
                                                <Border.Background>
                                                    <SolidColorBrush Color="#F59E0B" Opacity="0.15"/>
                                                </Border.Background>
                                                <TextBlock Text="⬡" FontSize="12" Foreground="#F59E0B"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="Сегментация" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextSecondary2Brush}"
                                                       VerticalAlignment="Center"/>
                                            <Border Background="#F59E0B15" CornerRadius="8" Padding="6,2"
                                                    Margin="8,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="3" FontSize="10" Foreground="#FCD34D" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <WrapPanel>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="{DynamicResource SurfaceInputBrush}" Padding="6,3">
                                                <TextBlock Text="Morphology" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Border>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="{DynamicResource SurfaceInputBrush}" Padding="6,3">
                                                <TextBlock Text="Edge Detect" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                            </Border>
                                            <Border Margin="0,2,4,2" CornerRadius="4" Background="#261E10" Padding="6,3">
                                                <TextBlock Text="Seam Carving" FontSize="9" Foreground="#FCD34D"/>
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Additional features row -->
                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="• Режим сравнения До/После — переключение вкладок и интерактивный слайдер."
                                       TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="22"/>
                            <TextBlock Text="• Оценка качества — расчёт метрик SSIM и PSNR между исходным и обработанным изображением."
                                       TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="22" Margin="0,4,0,0"/>
                            <TextBlock Text="• История обработок — список применённых методов с миниатюрами и метриками качества."
                                       TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="22" Margin="0,4,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Горячие клавиши"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary2Brush}"
                                   Margin="0,20,0,10"/>
                        <!-- Keyboard shortcut rows -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="12,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <Grid Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="5" Padding="8,3" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,1,2">
                                            <TextBlock Text="Ctrl+O" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondary2Brush}" FontFamily="Consolas"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="Открыть изображение" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="5" Padding="8,3" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,1,2">
                                        <TextBlock Text="Ctrl+S" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondary2Brush}" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Экспорт результата" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="5" Padding="8,3" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,1,2">
                                        <TextBlock Text="Ctrl+R" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondary2Brush}" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Сбросить обработку" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="5" Padding="8,3" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,1,2">
                                        <TextBlock Text="Ctrl+1/2/3" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondary2Brush}" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Вкладки До / После / Сравнение" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="5" Padding="8,3" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,1,2">
                                        <TextBlock Text="Ctrl+± " FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondary2Brush}" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Масштаб изображения" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="5" Padding="8,3" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,1,2">
                                        <TextBlock Text="Ctrl+H" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondary2Brush}" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="История обработок" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="5" Padding="8,3" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,1,2">
                                        <TextBlock Text="F1" FontSize="10" FontWeight="Bold" Foreground="#818CF8" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Справка и возможности" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                                <Grid Margin="0,3,0,3">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="120"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="5" Padding="8,3" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,1,2">
                                        <TextBlock Text="Escape" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextSecondary2Brush}" FontFamily="Consolas"/>
                                    </Border>
                                    <TextBlock Grid.Column="1" Text="Вписать изображение в окно" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Сценарии использования"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary2Brush}"
                                   Margin="0,20,0,6"/>
                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="• Криминалистика и видеонаблюдение — улучшение тёмных и шумных кадров с камер, восстановление деталей объектов."
                                       TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="22"/>
                            <TextBlock Text="• Медицина — повышение информативности МРТ, КТ, рентгеновских и ультразвуковых снимков."
                                       TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="22" Margin="0,4,0,0"/>
                            <TextBlock Text="• Научные и учебные задачи — обработка микроскопических, архивных и учебных изображений."
                                       TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="22" Margin="0,4,0,0"/>
                            <TextBlock Text="• Подготовка материалов — улучшение иллюстраций для отчётов, презентаций и публикаций."
                                       TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" LineHeight="22" Margin="0,4,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Метрики качества"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary2Brush}"
                                   Margin="0,20,0,10"/>

                        <!-- Metric cards side-by-side -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Margin="0,0,5,0" CornerRadius="10" ClipToBounds="True"
                                    Background="{DynamicResource CardBrush}"
                                    BorderBrush="#2A2A38" BorderThickness="1">
                                <Grid>
                                    <Border Height="3" VerticalAlignment="Top" CornerRadius="10,10,0,0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#6366F1" Offset="0"/>
                                                <GradientStop Color="#8B5CF6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <StackPanel Margin="14,15,14,14">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="SSIM" FontSize="20" FontWeight="Bold"
                                                       Foreground="#818CF8" Margin="0,0,8,0"/>
                                            <Border Background="#1A1A35" CornerRadius="12" Padding="8,3" VerticalAlignment="Center">
