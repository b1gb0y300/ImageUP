<Window x:Class="ImageEnhancementWpf.MethodWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Метод обработки"
        Height="520" Width="640"
        MinHeight="380" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip"
        Opacity="0"
        Loaded="Window_Loaded">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource WindowBackgroundStartColor}" Offset="0"/>
            <GradientStop Color="{DynamicResource WindowBackgroundEndColor}" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="MethodTitleText" Text="Метод"
                   FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,10"/>

        <Border Grid.Row="1" Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="10" Margin="0,0,0,10"
                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Width="80" Height="48" CornerRadius="6" Background="{DynamicResource ImageViewerBrush}"
                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" Margin="0,0,12,0">
                    <Image x:Name="SourceImageControl" Stretch="Uniform"/>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="SourceCaptionText" Text="Исходное с главного окна"
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="SourceSizeText" Text="" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="2" Content="Загрузить другое" Style="{StaticResource GhostButton}"
                        Padding="10,6" VerticalAlignment="Center"
                        x:Name="LoadSourceButton" Click="LoadSource_Click"/>
            </Grid>
        </Border>

        <Border x:Name="ParametersPanel" Grid.Row="2"
                Background="{DynamicResource CardBrush}" CornerRadius="10" Padding="12"
                Margin="0,0,0,10" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ParametersStack"/>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="3" Background="{DynamicResource CardBrush}"
                CornerRadius="12" Padding="10" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Результат" FontSize="12" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                <Border x:Name="ResultImageBorder" Grid.Row="1" Background="{DynamicResource ImageViewerBrush}" CornerRadius="8"
                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" MinHeight="140">
                    <Grid>
                        <Image x:Name="ResultImageControl" Stretch="Uniform"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Opacity="0" RenderTransformOrigin="0.5,0.5">
                            <Image.RenderTransform>
                                <ScaleTransform x:Name="ResultImageScale" ScaleX="1" ScaleY="1"/>
                            </Image.RenderTransform>
                        </Image>
                        <TextBlock x:Name="ResultPlaceholderText" Text="Нажмите «Применить»"
                                   Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Применить" Width="120" Height="36"
                    Style="{StaticResource AccentButton}"
                    Margin="0,0,10,0" Click="Apply_Click"/>
            <Button Content="Сохранить результат" Width="140" Height="36"
                    Style="{StaticResource GhostButton}"
                    Margin="0,0,10,0" Click="SaveResult_Click"/>
            <Button Content="Закрыть" Width="90" Height="36"
                    Style="{StaticResource GhostButton}"
                    Click="Close_Click"/>
        </StackPanel>
    </Grid>
</Window>
