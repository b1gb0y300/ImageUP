<Window x:Class="ImageEnhancementWpf.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ImageUP"
        Height="890" Width="1120"
        WindowStartupLocation="CenterScreen">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="{DynamicResource WindowBackgroundStartColor}" Offset="0"/>
            <GradientStop Color="{DynamicResource WindowBackgroundEndColor}" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <!-- Градиент героя — тёмно-фиолетовый, независимо от темы -->
        <LinearGradientBrush x:Key="HeroBackgroundBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#0F0B1E" Offset="0"/>
            <GradientStop Color="#1E1040" Offset="0.4"/>
            <GradientStop Color="#0A0814" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="HeroPrimaryButton" TargetType="Button" BasedOn="{StaticResource AccentButton}">
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="HeroSecondaryButton" TargetType="Button" BasedOn="{StaticResource GhostButton}">
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="618*"/>
            <RowDefinition Height="382*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ─── Шапка + герой ─────────────────────────────────────────── -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Навигация -->
            <Grid Grid.Row="0" Margin="34,13,34,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="IMAGEUP"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,4,0,8">
                    <Button Content="Возможности"
                            Width="150" Height="42"
                            Style="{StaticResource HeroSecondaryButton}"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            Click="HelpButton_Click"
                            Margin="0,0,8,0"/>
                    <Button Content="⚙" Width="42" Height="42"
                            Style="{StaticResource HeroSecondaryButton}"
                            FontSize="16" Padding="0"
                            ToolTip="Настройки"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            Click="SettingsButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Герой-секция -->
            <Grid Grid.Row="1" Margin="0,24,0,0">
                <Grid.Background>
                    <StaticResource ResourceKey="HeroBackgroundBrush"/>
                </Grid.Background>

                <Grid Margin="34,34,34,34">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center" MaxWidth="520">
                        <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="16"
                                Padding="10,4" Margin="0,0,0,18"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="18" Height="18" CornerRadius="9"
                                        Background="{DynamicResource CardBrush}" Margin="0,0,6,0">
                                    <TextBlock Text="✦" FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Версия 2.0 уже доступна"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Раскройте каждую деталь с невероятной точностью"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="#F4F4F5"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>

                        <TextBlock Text="Профессиональная платформа для улучшения и анализа изображений. Незаменимый инструмент для криминалистов, медицинских работников и исследователей, работающих с визуальными данными."
                                   FontSize="13"
                                   Foreground="#A1A1AA"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,24"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="Начать работу"
                                    Width="170" Height="42"
                                    Style="{StaticResource HeroPrimaryButton}"
                                    Cursor="Hand"
                                    Click="StartButton_Click"
                                    Margin="0,0,13,0"/>
                            <Button Content="История обработок"
                                    Width="170" Height="42"
                                    Style="{StaticResource HeroSecondaryButton}"
                                    Cursor="Hand"
                                    Click="HistoryButton_Click"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- ─── App Preview Mockup ───────────────────────── -->
                    <Border Grid.Column="1" Margin="34,0,0,0" CornerRadius="20"
                            ClipToBounds="True"
                            Background="#08080E"
                            BorderBrush="#252535" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="#6366F1" BlurRadius="40" ShadowDepth="0" Opacity="0.2"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="28"/>
                                <RowDefinition Height="*" MinHeight="160"/>
                                <RowDefinition Height="56"/>
                            </Grid.RowDefinitions>

                            <!-- Window chrome -->
                            <Border Grid.Row="0" Background="#111118" Padding="10,0">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="8" Height="8" Fill="#FF5F57" Margin="0,0,5,0"/>
                                        <Ellipse Width="8" Height="8" Fill="#FFBD2E" Margin="0,0,5,0"/>
                                        <Ellipse Width="8" Height="8" Fill="#28C840"/>
                                    </StackPanel>
                                    <TextBlock Text="ImageUP — Обработка изображений" FontSize="9"
                                               Foreground="#33334A"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- App body -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Methods panel -->
                                <Border Grid.Column="0" Background="#0F0F18"
                                        BorderBrush="#1E1E2A" BorderThickness="0,0,1,0"
                                        Padding="7,8">
                                    <StackPanel>
                                        <TextBlock Text="МЕТОДЫ" FontSize="6" FontWeight="Bold"
                                                   Foreground="#33334A" Margin="0,0,0,6"/>
                                        <TextBlock Text="Контраст" FontSize="7" Foreground="#44445A" Margin="0,0,0,3"/>
                                        <Border Height="18" CornerRadius="3" Background="#252535"
                                                BorderThickness="2,0,0,0" BorderBrush="#6366F1"
                                                Margin="0,0,0,2">
                                            <TextBlock Text="CLAHE" FontSize="7" Foreground="#818CF8"
                                                       VerticalAlignment="Center" Margin="5,0"/>
                                        </Border>
                                        <Border Height="18" CornerRadius="3" Background="#181824" Margin="0,0,0,2">
                                            <TextBlock Text="Gamma" FontSize="7" Foreground="#44445A"
                                                       VerticalAlignment="Center" Margin="7,0"/>
                                        </Border>
                                        <TextBlock Text="Шум" FontSize="7" Foreground="#44445A" Margin="0,6,0,3"/>
                                        <Border Height="18" CornerRadius="3" Background="#181824" Margin="0,0,0,2">
                                            <TextBlock Text="NLM" FontSize="7" Foreground="#44445A"
                                                       VerticalAlignment="Center" Margin="7,0"/>
                                        </Border>
                                        <Border Height="18" CornerRadius="3" Background="#181824" Margin="0,0,0,2">
                                            <TextBlock Text="Median" FontSize="7" Foreground="#44445A"
                                                       VerticalAlignment="Center" Margin="7,0"/>
                                        </Border>
                                        <TextBlock Text="Резкость" FontSize="7" Foreground="#44445A" Margin="0,6,0,3"/>
                                        <Border Height="18" CornerRadius="3" Background="#181824" Margin="0,0,0,2">
                                            <TextBlock Text="Unsharp" FontSize="7" Foreground="#44445A"
                                                       VerticalAlignment="Center" Margin="7,0"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Image viewer: before/after overlay split (single image) -->
                                <Border Grid.Column="1" Background="#0A0A14" ClipToBounds="True">
                                    <Grid>
                                        <!-- Layer 1: dim shapes (the "before" — covers full width) -->
                                        <Ellipse HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Width="140" Height="170" Opacity="0.13">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#8080CC" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <Ellipse HorizontalAlignment="Center" VerticalAlignment="Center"
                                                 Width="72" Height="88" Margin="22,-32,0,0" Opacity="0.08">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#A0A0DD" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!-- Layer 2: right-half enhanced overlay (clipped to right 50%) -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Right column: bright shapes centered at the same point as dim layer -->
                                            <Border Grid.Column="1" ClipToBounds="True">
                                                <Grid>
                                                    <!-- Ellipse centered at left edge of this column = center of full viewer -->
                                                    <Ellipse HorizontalAlignment="Left" VerticalAlignment="Center"
                                                             Width="140" Height="170" Margin="-70,0,0,0" Opacity="0.8">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush>
                                                                <GradientStop Color="#6366F1" Offset="0"/>
                                                                <GradientStop Color="Transparent" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <Ellipse HorizontalAlignment="Left" VerticalAlignment="Center"
                                                             Width="72" Height="88" Margin="-48,-32,0,0" Opacity="0.6">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush>
                                                                <GradientStop Color="#8B5CF6" Offset="0"/>
                                                                <GradientStop Color="Transparent" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <Ellipse HorizontalAlignment="Left" VerticalAlignment="Center"
                                                             Width="32" Height="40" Margin="-20,20,0,0" Opacity="0.5">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush>
                                                                <GradientStop Color="#A78BFA" Offset="0"/>
                                                                <GradientStop Color="Transparent" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                </Grid>
                                            </Border>
                                        </Grid>

                                        <!-- Labels -->
                                        <Border VerticalAlignment="Top" HorizontalAlignment="Left"
                                                Margin="6,5,0,0" Background="#181828" CornerRadius="3" Padding="4,2">
                                            <TextBlock Text="ДО" FontSize="8" Foreground="#44445A"/>
                                        </Border>
                                        <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                                Margin="0,5,6,0" Background="#18183A" CornerRadius="3" Padding="4,2">
                                            <TextBlock Text="ПОСЛЕ" FontSize="8" Foreground="#6366F1"/>
                                        </Border>

                                        <!-- Divider with glow -->
                                        <Border Width="2" HorizontalAlignment="Center">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="Transparent" Offset="0"/>
                                                    <GradientStop Color="#6366F1" Offset="0.2"/>
                                                    <GradientStop Color="#8B5CF6" Offset="0.8"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#6366F1" BlurRadius="8" ShadowDepth="0" Opacity="0.9"/>
                                            </Border.Effect>
                                        </Border>

                                        <!-- Handle circle -->
                                        <Border Width="22" Height="22" CornerRadius="11"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#6366F1" Offset="0"/>
                                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Border.Effect>
                                                <DropShadowEffect Color="#6366F1" BlurRadius="14" ShadowDepth="0" Opacity="0.7"/>
                                            </Border.Effect>
                                            <TextBlock Text="⟷" FontSize="9" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Metrics bar -->
                            <Border Grid.Row="2" Background="#0F0F18"
                                    BorderBrush="#1E1E2A" BorderThickness="0,1,0,0"
                                    Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="SSIM" FontSize="8" Foreground="#44445A" HorizontalAlignment="Center"/>
                                        <TextBlock Text="0.947" FontSize="18" FontWeight="Bold"
                                                   Foreground="#6366F1" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#252535"/>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="PSNR" FontSize="8" Foreground="#44445A" HorizontalAlignment="Center"/>
                                        <TextBlock Text="32.4 dB" FontSize="16" FontWeight="Bold"
                                                   Foreground="#8B5CF6" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                    <Border Grid.Column="3" Background="#252535"/>
                                    <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                        <TextBlock Text="МЕТОД" FontSize="8" Foreground="#44445A" HorizontalAlignment="Center"/>
                                        <TextBlock Text="CLAHE" FontSize="14" FontWeight="Bold"
                                                   Foreground="#A78BFA" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- ─── Карточки специализаций ─────────────────────────────────── -->
        <Grid Grid.Row="1" Background="{DynamicResource DarkPanelBrush}">
            <StackPanel Margin="34,21,34,21">
                <TextBlock Text="Специализированные решения для профессионалов"
                           FontSize="20" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Проверенные алгоритмы обработки визуальной информации для разных сценариев применения."
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,24"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Margin="0,0,16,0" Padding="20" CornerRadius="18"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <Border Width="32" Height="32" CornerRadius="16" Margin="0,0,0,10" Background="#EF4444">
                                <Border.OpacityMask>
                                    <ImageBrush ImageSource="crime.png" Stretch="Uniform"/>
                                </Border.OpacityMask>
                            </Border>
                            <TextBlock Text="Криминалистика" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="Повышение чёткости записей с камер видеонаблюдения, выделение деталей на местах происшествий, восстановление смазанных объектов."
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="• Устранение шумов"       FontSize="11" Foreground="#F97373"/>
                                <TextBlock Text="• Восстановление фокуса"  FontSize="11" Foreground="#F97373"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="0,0,16,0" Padding="20" CornerRadius="18"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <Border Width="32" Height="32" CornerRadius="16" Margin="0,0,0,10" Background="#2563EB">
                                <Border.OpacityMask>
                                    <ImageBrush ImageSource="medicine.png" Stretch="Uniform"/>
                                </Border.OpacityMask>
                            </Border>
                            <TextBlock Text="Медицина" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="Улучшение контрастности и детализации МРТ, КТ, рентген-снимков и УЗИ. Помощь врачам в обнаружении микропатологий."
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="• Подчёркивание границ тканей" FontSize="11" Foreground="#60A5FA"/>
                                <TextBlock Text="• HDR обработка снимков"       FontSize="11" Foreground="#60A5FA"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="20" CornerRadius="18"
                            Background="{DynamicResource CardBrush}"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <Border Width="32" Height="32" CornerRadius="16" Margin="0,0,0,10" Background="#16A34A">
                                <Border.OpacityMask>
                                    <ImageBrush ImageSource="nauka.png" Stretch="Uniform"/>
                                </Border.OpacityMask>
                            </Border>
                            <TextBlock Text="Наука и обучение" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                            <TextBlock Text="Анализ микроскопических и архивных снимков, восстановление выцветших документов и графиков, демонстрация методов обработки студентам."
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="• Макромасштабирование"  FontSize="11" Foreground="#4ADE80"/>
                                <TextBlock Text="• Восстановление текста" FontSize="11" Foreground="#4ADE80"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- ─── Футер ─────────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceInputBrush}" Padding="32,10">
            <TextBlock Text="© 2026 ImageUP Platform. Все права защищены."
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"/>
        </Border>
    </Grid>
</Window>
