<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>upload.ico</ApplicationIcon>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <Content Include="upload.ico">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
    <Content Include="Models\**\*" CopyToOutputDirectory="PreserveNewest" Link="Models\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <!-- PNG-иконки для WelcomeWindow -->
  <ItemGroup>
    <Resource Include="crime.png" />
    <Resource Include="medicine.png" />
    <Resource Include="nauka.png" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.19.2" />
    <PackageReference Include="QuestPDF" Version="2026.2.4" />
    <PackageReference Include="System.Drawing.Common" Version="9.0.11" />
  </ItemGroup>

  </Project>
