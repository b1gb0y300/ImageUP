<Window x:Class="ImageEnhancementWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ImageUP — улучшение качества изображений"
        Height="900" Width="1280"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragEnter="Window_DragEnter"
        DragLeave="Window_DragLeave"
        Drop="Window_Drop">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource WindowBackgroundStartColor}" Offset="0"/>
            <GradientStop Color="{DynamicResource WindowBackgroundEndColor}" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
        <Style x:Key="LoadingProgressBar" TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource AccentGradient}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Height" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="3" ClipToBounds="True"/>
                            <Border x:Name="Animation" Background="{TemplateBinding Foreground}" CornerRadius="3"
                                    HorizontalAlignment="Left" Width="80">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="Transform"/>
                                </Border.RenderTransform>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetName="Transform"
                                                                 Storyboard.TargetProperty="X"
                                                                 From="0" To="240" Duration="0:0:1.2"
                                                                 AutoReverse="True">
                                                    <DoubleAnimation.EasingFunction>
                                                        <QuadraticEase EasingMode="EaseInOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}"
                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#6366F1" Offset="0"/>
                            <GradientStop Color="#8B5CF6" Offset="0.5"/>
                            <GradientStop Color="#EC4899" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Grid Grid.Row="1" Margin="16,10,16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="32" Height="32" CornerRadius="8" Margin="0,0,10,0"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#6366F1" Offset="0"/>
                                    <GradientStop Color="#8B5CF6" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Image x:Name="UploadIconImage" Width="20" Height="20"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Image" FontSize="18" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="UP" FontSize="18" FontWeight="Bold"
                                           Foreground="#6366F1"/>
                            </StackPanel>
                            <TextBlock Text="Обработка и анализ изображений"
                                       FontSize="10" Foreground="{DynamicResource TextMutedBrush}" Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="6"
                                Padding="10,5" BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Ctrl+O" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#6366F1" VerticalAlignment="Center"/>
                                <TextBlock Text=" открыть  " FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Ctrl+V" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#6366F1" VerticalAlignment="Center"/>
                                <TextBlock Text=" вставить  " FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="Ctrl+E" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#6366F1" VerticalAlignment="Center"/>
                                <TextBlock Text=" отчёт  " FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="F1" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#6366F1" VerticalAlignment="Center"/>
                                <TextBlock Text=" помощь" FontSize="10"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="📂  Открыть" Height="34" Padding="12,0"
                                Style="{StaticResource GhostButton}"
                                Margin="0,0,6,0" Click="LoadImage_Click" ToolTip="Загрузить изображение (Ctrl+O)"/>
                        <Button Content="💾  Сохранить" Height="34" Padding="12,0"
                                Style="{StaticResource GhostButton}"
                                Click="SaveImage_Click" ToolTip="Сохранить результат (Ctrl+S)" Margin="0,0,6,0"/>
                        <Button Content="📄  PDF" Height="34" Padding="12,0"
                                Style="{StaticResource AccentButton}"
                                Click="ExportReport_Click" ToolTip="Экспорт PDF-отчёта (Ctrl+E)" Margin="0,0,6,0"/>
                        <Button Content="📋" Width="34" Height="34" Style="{StaticResource GhostButton}"
                                FontSize="15" Padding="0"
                                ToolTip="История обработок (Ctrl+H)"
                                Click="History_Click" Margin="0,0,6,0"/>
                        <Button Content="⚙" Width="34" Height="34" Style="{StaticResource GhostButton}"
                                FontSize="15" Padding="0"
                                ToolTip="Настройки"
                                Click="Settings_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="180"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="256" MinWidth="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Background="{DynamicResource LeftPanelBrush}"
                    Padding="13"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0">
                    <StackPanel Margin="0,0,6,0">
                        <TextBlock x:Name="MethodsHeaderText" Text="МЕТОДЫ (18)"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,12"/>
                        <ItemsControl x:Name="MethodGroupsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,14">
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" CornerRadius="2"
                                                    Background="{Binding CategoryColor}"
                                                    Margin="0,1,0,1"/>
                                            <TextBlock Grid.Column="1" Text="{Binding CategoryName}"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       Margin="7,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                        <ItemsControl ItemsSource="{Binding Items}"
                                                      HorizontalContentAlignment="Stretch">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,3"
                                                            Padding="9,7"
                                                            CornerRadius="7"
                                                            Background="{DynamicResource SurfaceInputBrush}"
                                                            BorderBrush="{DynamicResource BorderSubtleBrush}"
                                                            BorderThickness="1"
                                                            Cursor="Hand"
                                                            HorizontalAlignment="Stretch"
                                                            MouseLeftButtonDown="MethodListItem_Click">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#1A1A30"/>
                                                                        <Setter Property="BorderBrush" Value="#6366F1"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{DynamicResource CardBrush}"/>
                                                                        <Setter Property="BorderBrush" Value="#4F46E5"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="22"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0"
                                                                    Width="18" Height="18"
                                                                    CornerRadius="4"
                                                                    Background="{Binding CategoryAccentBrush}"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Icon}"
                                                                           FontSize="10"
                                                                           Foreground="White"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                                       FontSize="11.5"
                                                                       Foreground="{DynamicResource TextSecondary2Brush}"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Center"
                                                                       Margin="7,0,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Grid Grid.Column="1" Grid.Row="0" Margin="12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="6" Padding="6,4"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Button x:Name="ZoomOutButton" Content="−" Width="24" Height="24"
                                    Style="{StaticResource GhostButton}"
                                    FontSize="14" Padding="0" Click="ZoomOut_Click"/>
                            <TextBlock x:Name="CenterZoomText" Text="100%" FontSize="11"
                                       Foreground="{DynamicResource TextSecondary2Brush}"
                                       VerticalAlignment="Center" Margin="6,0" MinWidth="32"/>
                            <Button x:Name="ZoomInButton" Content="+" Width="24" Height="24"
                                    Style="{StaticResource GhostButton}"
                                    FontSize="14" Padding="0" Click="ZoomIn_Click"/>
                            <Border Width="1" Height="14" Margin="6,0"
                                    Background="{DynamicResource BorderSubtleBrush}"/>
                            <Button Content="⤢" Width="24" Height="24" Style="{StaticResource GhostButton}"
                                    FontSize="11" Padding="0" ToolTip="Вписать" Click="FitZoom_Click"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                  <StackPanel Orientation="Horizontal">
                        <Border x:Name="TabBefore" Background="{DynamicResource TabActiveBrush}"
                                CornerRadius="8,8,0,0" Padding="14,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,0,0"
                                Cursor="Hand" MouseLeftButtonDown="TabBefore_Click">
                            <StackPanel>
                                <TextBlock Text="ДО ОБРАБОТКИ" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary2Brush}"/>
                                <Border x:Name="TabBeforeBar" Height="2" CornerRadius="1"
                                        Background="{DynamicResource AccentBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="TabAfter" Background="{DynamicResource TabInactiveBrush}"
                                CornerRadius="8,8,0,0" Padding="14,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,0,0"
                                Cursor="Hand" MouseLeftButtonDown="TabAfter_Click">
                            <StackPanel>
                                <TextBlock Text="ПОСЛЕ ОБРАБОТКИ" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <Border x:Name="TabAfterBar" Height="2" CornerRadius="1"
                                        Background="{DynamicResource AccentBrush}" Margin="0,4,0,0"
                                        Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="TabCompare" Background="{DynamicResource TabInactiveBrush}"
                                CornerRadius="8,8,0,0" Padding="14,8"
                                BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,1,0"
                                Cursor="Hand" MouseLeftButtonDown="TabCompare_Click" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock x:Name="TabCompareText" Text="СРАВНЕНИЕ" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}"/>
                                <Border x:Name="TabCompareBar" Height="2" CornerRadius="1"
                                        Background="{DynamicResource AccentBrush}" Margin="0,4,0,0"
                                        Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                  </StackPanel>

                  <Border x:Name="PipelineBar" Visibility="Collapsed" Margin="0,6,0,0"
                          Background="{DynamicResource SurfaceInputBrush}" CornerRadius="8" Padding="8,6"
                          BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                      <Grid>
                          <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="*"/>
                              <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                        VerticalScrollBarVisibility="Disabled" Padding="0">
                              <StackPanel x:Name="PipelineStepsPanel" Orientation="Horizontal"
                                          VerticalAlignment="Center"/>
                          </ScrollViewer>
                          <Button Grid.Column="1" Content="↺ Сбросить" Height="26" Padding="8,0"
                                  Style="{StaticResource GhostButton}" FontSize="11"
                                  Margin="8,0,0,0" Click="PipelineReset_Click"
                                  ToolTip="Сбросить цепочку и вернуться к оригиналу"/>
                      </Grid>
                  </Border>
                </StackPanel>

                <Border Grid.Row="2" Background="{DynamicResource ImageViewerBrush}"
                        CornerRadius="0,0,8,8" Padding="0"
                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                    <Grid>
                        <Grid x:Name="OriginalPanel" Visibility="Visible">
                            <Grid>
                                <ScrollViewer x:Name="OriginalScrollViewer"
                                             HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                             PanningMode="None" Background="{DynamicResource ImageViewerBrush}"
                                             PreviewMouseWheel="OriginalScrollViewer_PreviewMouseWheel">
                                    <Border x:Name="OriginalImageContainer"
                                            Background="{DynamicResource ImageViewerBrush}"
                                            BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            PreviewMouseLeftButtonDown="OriginalImage_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="OriginalImage_PreviewMouseMove"
                                            PreviewMouseLeftButtonUp="OriginalImage_PreviewMouseLeftButtonUp"
                                            MouseLeave="OriginalImage_MouseLeave">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                        <Border.LayoutTransform>
                                            <ScaleTransform x:Name="OriginalImageScale" ScaleX="1" ScaleY="1"/>
                                        </Border.LayoutTransform>
                                        <Image x:Name="OriginalImageControl" Stretch="Uniform"/>
                                    </Border>
                                </ScrollViewer>
                                <Border x:Name="LoadZoneBorder"
                                        Background="{DynamicResource ImageViewerBrush}"
                                        Cursor="Hand"
                                        BorderBrush="#3F3F46" BorderThickness="2"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                        Margin="40" CornerRadius="12"
                                        MouseLeftButtonDown="LoadZone_Click"
                                        AllowDrop="True"
                                        DragEnter="LoadZone_DragEnter"
                                        DragLeave="LoadZone_DragLeave"
                                        Drop="LoadZone_Drop">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#6366F1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="📤" FontSize="48" Foreground="#52525B" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="OriginalPlaceholder" Text="Загрузите изображение"
                                                   Foreground="{DynamicResource TextMutedBrush}"
                                                   FontSize="14" HorizontalAlignment="Center"
                                                   Margin="0,8,0,0"/>
                                        <TextBlock Text="Перетащите файл или нажмите для выбора (Ctrl+O)"
                                                   Foreground="#52525B" FontSize="11" HorizontalAlignment="Center"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>

                        <Grid x:Name="ProcessedPanel" Visibility="Collapsed">
                            <Grid>
                                <ScrollViewer x:Name="ProcessedScrollViewer"
                                             HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                             PanningMode="None" Background="{DynamicResource ImageViewerBrush}"
                                             PreviewMouseWheel="ProcessedScrollViewer_PreviewMouseWheel">
                                    <Border x:Name="ProcessedImageContainer"
                                            Background="{DynamicResource ImageViewerBrush}"
                                            BorderBrush="#3F3F46" BorderThickness="1" CornerRadius="6"
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            PreviewMouseLeftButtonDown="ProcessedImage_PreviewMouseLeftButtonDown"
                                            PreviewMouseMove="ProcessedImage_PreviewMouseMove"
                                            PreviewMouseLeftButtonUp="ProcessedImage_PreviewMouseLeftButtonUp"
                                            MouseLeave="ProcessedImage_MouseLeave">
                                        <Border.Effect>
                                            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                                        </Border.Effect>
                                        <Border.LayoutTransform>
                                            <ScaleTransform x:Name="ProcessedImageScale" ScaleX="1" ScaleY="1"/>
                                        </Border.LayoutTransform>
                                        <Image x:Name="ProcessedImageControl" Stretch="Uniform"/>
                                    </Border>
                                </ScrollViewer>
                                <TextBlock x:Name="ProcessedPlaceholder" Text="Результат обработки"
                                           Foreground="#52525B" FontSize="14" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </Grid>
                        </Grid>

                        <Grid x:Name="ComparePanel" Visibility="Collapsed"
                              Background="{DynamicResource ImageViewerBrush}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <ScrollViewer Grid.Row="0" x:Name="CompareScrollViewer"
                                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                          PreviewMouseWheel="CompareScrollViewer_PreviewMouseWheel">
                                <Border x:Name="CompareZoomContainer" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Background="{DynamicResource ImageViewerBrush}"
                                        PreviewMouseLeftButtonDown="CompareImage_PreviewMouseLeftButtonDown"
                                        PreviewMouseMove="CompareImage_PreviewMouseMove"
                                        PreviewMouseLeftButtonUp="CompareImage_PreviewMouseLeftButtonUp"
                                        MouseLeave="CompareImage_MouseLeave">
                                    <Border.LayoutTransform>
                                        <ScaleTransform x:Name="CompareImageScale" ScaleX="1" ScaleY="1"/>
                                    </Border.LayoutTransform>
                                    <Viewbox x:Name="CompareViewbox" Stretch="Uniform">
                                        <Border x:Name="CompareImageContainer" SizeChanged="CompareContainer_SizeChanged">
                                    <Grid>
                                        <Image x:Name="CompareOriginalImage" Stretch="Uniform"/>
                                        <Image x:Name="CompareProcessedImage" Stretch="Uniform">
                                            <Image.Clip>
                                                <RectangleGeometry x:Name="CompareProcessedClip" Rect="0,0,0,0"/>
                                            </Image.Clip>
                                        </Image>
                                        <Border x:Name="CompareDivider" Width="2" HorizontalAlignment="Left"
                                                Background="#E4E4E7" Cursor="SizeWE"
                                                MouseLeftButtonDown="CompareDivider_MouseDown"
                                                MouseMove="CompareDivider_MouseMove"
                                                MouseLeftButtonUp="CompareDivider_MouseUp">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="2" ShadowDepth="0" Opacity="0.5"/>
                                            </Border.Effect>
                                        </Border>
                                    </Grid>
                                </Border>
                                    </Viewbox>
                                </Border>
                            </ScrollViewer>
                            <Slider Grid.Row="1" x:Name="CompareSlider" Minimum="0" Maximum="100" Value="50"
                                    Margin="24,8,24,12" Height="16"
                                    Style="{StaticResource DarkSlider}"
                                    ValueChanged="CompareSlider_ValueChanged"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="3" Background="{DynamicResource SurfaceInputBrush}"
                        CornerRadius="0,0,8,8" Padding="10,5"
                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,0,1,1"
                        Margin="0,2,0,0">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="InfoOrigDimText" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextSecondary2Brush}"
                                       VerticalAlignment="Center" Text="—"/>
                            <TextBlock x:Name="InfoSepArrow" Text="  →  " FontSize="11"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" Visibility="Collapsed"/>
                            <TextBlock x:Name="InfoProcDimText" FontSize="11"
                                       Foreground="#22C55E"
                                       VerticalAlignment="Center" Visibility="Collapsed"/>
                            <TextBlock x:Name="InfoFileMeta" FontSize="10"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       VerticalAlignment="Center" Margin="12,0,0,0" Text=""/>
                        </StackPanel>
                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                   FontSize="10" Foreground="#3F3F46"
                                   Text="Ctrl+O открыть · Ctrl+V вставить · Ctrl+S сохранить · Ctrl+E отчёт"/>
                    </Grid>
                </Border>

                <Grid x:Name="LoadingOverlay" Visibility="Collapsed" Panel.ZIndex="1000"
                      Grid.RowSpan="4" Margin="0">
                    <Border Background="#80000000"/>
                    <Border Background="{DynamicResource LoadingCardBrush}" CornerRadius="16" Padding="32,24"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Применяем метод..." FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,12" HorizontalAlignment="Center"/>
                            <Border Width="220" Height="6"
                                    Background="{DynamicResource BorderSubtleBrush}"
                                    CornerRadius="3" ClipToBounds="True">
                                <ProgressBar Style="{StaticResource LoadingProgressBar}" Width="220" Height="6"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Column="1" Grid.Row="1"
                    Background="{DynamicResource DarkPanelBrush}"
                    BorderBrush="{DynamicResource BorderSubtleBrush}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Padding="16,10"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <TextBlock x:Name="MethodDetailTitle" Text="Выберите метод слева"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,6"/>
                                <TextBlock Text="Формула" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,3"/>
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="6" Padding="8"
                                        Margin="0,0,0,6"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                                  MaxHeight="44" Padding="0">
                                        <StackPanel x:Name="MethodDetailFormulaPanel"/>
                                    </ScrollViewer>
                                </Border>
                                <TextBlock Text="Принцип работы" FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,3"/>
                                <TextBlock x:Name="MethodDetailPrinciple" Text=""
                                           FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" LineHeight="16" Margin="0,0,0,6" MaxHeight="32"/>
                                <Border x:Name="MethodParametersPanel" Visibility="Collapsed"
                                        Background="{DynamicResource CardBrush}"
                                        CornerRadius="8" Padding="10" Margin="0,0,0,6"
                                        BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="90">
                                        <StackPanel x:Name="MethodParametersStack"/>
                                    </ScrollViewer>
                                </Border>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="MethodApplyButton" Content="Применить"
                                            MinWidth="100" Height="32" Padding="10,5"
                                            Style="{StaticResource AccentButton}"
                                            Margin="0,0,6,0" Click="MethodApply_Click"
                                            ToolTip="Применить к оригиналу (сбросит цепочку)"/>
                                    <Button x:Name="MethodResetButton" Content="Сбросить"
                                            MinWidth="70" Height="32" Padding="8,5"
                                            Style="{StaticResource GhostButton}"
                                            Click="MethodReset_Click" Margin="0,0,6,0"/>
                                    <Button x:Name="MethodChainButton"
                                            Content="+ В цепочку"
                                            MinWidth="120" Height="32" Padding="10,0"
                                            Style="{StaticResource GhostButton}"
                                            FontSize="11" IsEnabled="False"
                                            Click="MethodChainApply_Click"
                                            ToolTip="Применить к результату предыдущего шага (Ctrl+K)"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="1" Padding="14,10"
                            BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                        <StackPanel>
                            <TextBlock Text="Оценка качества" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondary2Brush}" Margin="0,0,0,8"/>
                            <Border Background="{DynamicResource SurfaceInputBrush}" CornerRadius="10" Padding="12"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" Cursor="Hand"
                                    MouseEnter="QualityCard_MouseEnter"
                                    MouseLeave="QualityCard_MouseLeave">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Метрики качества" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextSecondary2Brush}"/>
                                        <TextBlock Text="SSIM, PSNR" FontSize="10"
                                                   Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Border x:Name="QualityCurtain" Opacity="0"
                                            Background="{DynamicResource SurfaceInputBrush}"
                                            CornerRadius="10" Padding="10">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Сравнение исходного и обработанного изображения."
                                                       FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <Button Content="Открыть оценку качества"
                                                    FontSize="10" Padding="8,5" HorizontalAlignment="Left"
                                                    Style="{StaticResource AccentButton}"
                                                    Click="QualityCard_OpenClick"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="Информация" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondary2Brush}" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Размер" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoPanelDimText" Grid.Column="1" Text="—"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary2Brush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Каналы / DPI" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoPanelModeText" Grid.Column="1" Text="—"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary2Brush}"/>
                            </Grid>
                            <Grid Margin="0,0,0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Файл" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoPanelFileText" Grid.Column="1" Text="—"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextSecondary2Brush}"
                                           TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                            </Grid>
                            <Grid x:Name="InfoPanelProcRow" Margin="0,0,0,3" Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="После обработки" FontSize="10" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <TextBlock x:Name="InfoPanelProcText" Grid.Column="1" Text="—"
                                           FontSize="10" FontWeight="SemiBold" Foreground="#22C55E"/>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,3">
                                <TextBlock Text="Гистограмма" FontSize="9" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center"/>
                                <Border Width="7" Height="7" CornerRadius="2" Background="#6366F1" Margin="6,0,3,0"/>
                                <TextBlock Text="оригинал" FontSize="9" Foreground="{DynamicResource TextMutedBrush}"/>
                                <Border x:Name="HistLegendProcDot" Width="7" Height="7" CornerRadius="2"
                                        Background="#22C55E" Margin="6,0,3,0" Visibility="Collapsed"/>
                                <TextBlock x:Name="HistLegendProcText" Text="результат" FontSize="9"
                                           Foreground="{DynamicResource TextMutedBrush}" Visibility="Collapsed"/>
                            </StackPanel>
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="5" Padding="4,3"
                                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1" ClipToBounds="True">
                                <Canvas x:Name="HistogramCanvas" Height="56"
                                        SizeChanged="HistogramCanvas_SizeChanged"/>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border x:Name="DragOverlay" Visibility="Collapsed" Panel.ZIndex="999"
                Grid.RowSpan="2"
                Background="#B2000000"
                MouseLeave="DragOverlay_MouseLeave">
            <Border Background="{DynamicResource CardBrush}" CornerRadius="20" Padding="48,32"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#6366F1" BorderThickness="2">
                <Border.Effect>
                    <DropShadowEffect Color="#6366F1" BlurRadius="30" ShadowDepth="0" Opacity="0.5"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="📂" FontSize="56" HorizontalAlignment="Center"/>
                    <TextBlock Text="Отпустите для загрузки" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="0,14,0,4" HorizontalAlignment="Center"/>
                    <TextBlock Text="PNG, JPG, JPEG, BMP"
                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>

    </Grid>

</Window>
