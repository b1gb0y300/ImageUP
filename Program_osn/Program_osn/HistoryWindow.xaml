<Window x:Class="ImageEnhancementWpf.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История обработок — ImageUP"
        Width="900" Height="660"
        MinWidth="600" MinHeight="400"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource DarkScrollBar}"/>
    </Window.Resources>

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{DynamicResource WindowBackgroundStartColor}" Offset="0"/>
            <GradientStop Color="{DynamicResource WindowBackgroundEndColor}" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="История обработок"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock x:Name="SubtitleText"
                           Text="Загрузка..."
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="ClearAllButton"
                        Content="Очистить всё" Height="36" Padding="14,0"
                        Style="{StaticResource GhostButton}"
                        Click="ClearAll_Click" Margin="0,0,8,0"/>
                <Button Content="Закрыть" Height="36" Padding="14,0"
                        Style="{StaticResource AccentButton}"
                        Click="Close_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="344" MinWidth="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource CardBrush}"
                    CornerRadius="16,0,0,16"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,0,1"
                    Padding="21" Margin="0,0,0,0"
                    Effect="{StaticResource CardShadow}">
                <StackPanel x:Name="StatsPanel">
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Background="{DynamicResource CardBrush}"
                    CornerRadius="0,16,16,0"
                    BorderBrush="{DynamicResource BorderSubtleBrush}" BorderThickness="1,1,1,1"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid x:Name="EmptyPanel" Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="История пуста"
                                       FontSize="16" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="Применяйте методы обработки, и здесь появятся карточки с результатами и метриками качества."
                                       FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                                       HorizontalAlignment="Center" TextAlignment="Center"
                                       MaxWidth="320" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer x:Name="CardsScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="13">
                        <WrapPanel x:Name="CardsPanel"
                                   Orientation="Horizontal"
                                   HorizontalAlignment="Left"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
